# AoiTalk Voice Assistant - Environment Configuration Sample
# Copy this file to .env and configure your API keys and settings

# =============================================================================
# API Keys (必須/Required)
# =============================================================================

# OpenAI API Key
OPENAI_API_KEY=your-openai-api-key-here

# Discord Bot Token (Discord Bot 使用時のみ)
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Gemini API Key
GEMINI_API_KEY=your-gemini-api-key-here

# xAI Grok (X検索) API Key
XAI_API_KEY=your-xai-api-key-here
# XAI_GROK_MODEL=grok-4-0709
# XAI_API_BASE=https://api.x.ai/v1

# Nijivoice API Key (にじボイス使用時)
NIJIVOICE_API_KEY=your-nijivoice-api-key-here

# OpenWeatherMap API Key (天気情報取得用、オプション)
# https://openweathermap.org/api から無料で取得可能
OPENWEATHER_API_KEY=your-openweather-api-key-here

# ClickUp API Key & Team ID (タスク管理機能用)
# https://app.clickup.com/settings/apps でPersonal API Tokenを取得
CLICKUP_API_KEY=your-clickup-api-key-here
CLICKUP_TEAM_ID=your-clickup-team-id-here
# デフォルトリストID（任意）
# CLICKUP_DEFAULT_LIST_ID=your-default-list-id-here
# タスク同期対象フォルダID（カンマ区切りで複数指定可能）
# CLICKUP_TARGET_FOLDER_IDS=your-folder-id-1,your-folder-id-2

# ── TTS エンジンパス ────────────────────────────────────────
# 存在しない場合は自動的にフォールバックします
VOICEVOX_ENGINE_PATH=$HOME/voicevox_core/linux-nvidia/run
VOICEROID_ENGINE_PATH="%PROGRAMFILES%\AHS\VOICEROID2\VoiceroidEditor.exe"
COEIROINK_ENGINE_PATH=/path/to/COEIROINKv2.exe
AIVOICE_ENGINE_PATH="%PROGRAMFILES%\AI\AIVoice\AIVoiceEditor\AIVoiceEditor.exe" # (Windows only)
CEVIO_ENGINE_PATH="%PROGRAMFILES%\CeVIO\CeVIO AI\CeVIO AI.exe" # (Windows only)
AIVISSPEECH_ENGINE_PATH="%LOCALAPPDATA%\Programs\AivisSpeech\AivisSpeech-Engine\run.exe"

# フォールバック用パス
VOICEVOX_ENGINE_FALLBACK_PATH="%LOCALAPPDATA%\Programs\VOICEVOX\vv-engine\run.exe"
VOICEROID_ENGINE_FALLBACK_PATH=/path/to/voiceroid_fallback
COEIROINK_ENGINE_FALLBACK_PATH=/path/to/coeiroink_fallback
AIVOICE_ENGINE_FALLBACK_PATH=
CEVIO_ENGINE_FALLBACK_PATH=
AIVISSPEECH_ENGINE_FALLBACK_PATH="%LOCALAPPDATA%\Programs\AivisSpeech\AivisSpeech-Engine\run.exe"

# VOICEVOX host and port
VOICEVOX_HOST=127.0.0.1
VOICEVOX_PORT=50021

# AivisSpeech host and port
AIVISSPEECH_HOST=127.0.0.1
AIVISSPEECH_PORT=10101

# Audio Player ディレクトリ (音楽ファイルの格納先)
AUDIO_PLAYER_DIR=/path/to/your/audio_directory

# WSL PulseAudio Runtime Path (WSL 環境でのみ必要)
PULSE_RUNTIME_PATH=/mnt/wslg/runtime-dir/pulse

# ── Spotify API 設定 ───────────────────────────────────────
# https://developer.spotify.com/dashboard でアプリを作成
SPOTIFY_CLIENT_ID=your-spotify-client-id-here
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret-here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/callback

# ── PostgreSQL 設定 ───────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aoitalk_memory
POSTGRES_USER=aoitalk
POSTGRES_PASSWORD=your-secure-password-here

# メモリ管理 (PostgreSQL + pgvector を使用する場合は true に)
USE_POSTGRESQL=true

# PostgreSQL を用意できない場合の一時的な回避策
AOITALK_DISABLE_SEMANTIC_MEMORY=0

# SQLite 用ライブラリパスの調整 (必要に応じて)
LD_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu

# ── デバッグ設定 ────────────────────────────────────────
# Discord Bot音声受信のデバッグモード（debug_audioディレクトリに音声ファイルを保存）
# AOITALK_DEBUG=true

# ── WebUI ログイン設定 ─────────────────────────────────
AOITALK_WEB_AUTH_USER=your-webui-username
AOITALK_WEB_AUTH_PASSWORD=your-webui-password
AOITALK_WEB_AUTH_SECRET=your-webui-secret

# ── HuggingFace バックアップ設定 ────────────────────────────
# https://huggingface.co でリポジトリを作成
HUGGINGFACE_REPO_ID=your-huggingface-username/your-repo-name

# ── OS操作ツール設定 ─────────────────────────────────────
# コマンド実行・ファイル編集を許可するディレクトリ（カンマ区切り）
# 未設定の場合は制限なし
# AOITALK_ALLOWED_PATHS=/path/to/workspace1,/path/to/workspace2
# コマンドタイムアウト（秒）
AOITALK_COMMAND_TIMEOUT=120

# ── ドキュメント（メモ帳）設定 ─────────────────────────────────
# ドキュメント保存ディレクトリ（デフォルト: ./documents）
# AOITALK_DOCUMENTS_DIR=./documents

# ── SGLang / ローカルLLM設定 ─────────────────────────────────────
# SGLang等のOpenAI互換APIを持つローカルLLMサーバーを使用する場合
# llm_provider: sglang を設定し、以下の環境変数を設定してください
# SGLANG_BASE_URL=http://localhost:30000/v1
# SGLANG_MODEL=meta-llama/Llama-3.1-8B-Instruct
# SGLANG_API_KEY=dummy

# ── メディアブラウザ設定 ─────────────────────────────────────────
# ローカルメディアファイル（動画・画像）の閲覧用ディレクトリ
MEDIA_VIDEO_PATH=/path/to/media/videos
MEDIA_IMAGE_PATH=/path/to/media/images

# ── RAG (Qdrant + BGE) 設定 ─────────────────────────────────────
# Qdrantベクトルデータベースへの接続設定
# Docker: docker run -p 6333:6333 -p 6334:6334 qdrant/qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY=  # Qdrant Cloud使用時

# ── Docker環境設定 ────────────────────────────────────────────────
# docker-compose使用時はこれらの値はdocker-compose.ymlで自動設定されます
# 以下はDocker環境での動作を制御するための設定です

# Docker環境検出フラグ (docker-compose.ymlで自動設定)
# AOITALK_DOCKER=true

# Headlessモード (Docker内で音声出力を無効化)
# Docker環境では自動的にtrueになります
# AOITALK_HEADLESS=true

# ホスト設定 (docker-compose使用時は自動設定)
# POSTGRES_HOST=postgres
# QDRANT_HOST=qdrant
# VOICEVOX_HOST=voicevox
# AIVISSPEECH_HOST=aivisspeech
